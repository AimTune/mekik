{
  "name": "@mekik/examples",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "mekik examples — scripted and LLM-driven agents over the mekik/1 protocol: refunds, SQL, weather, and a concierge that combines them.",
  "scripts": {
    "selftest": "node refund.ts",
    "serve": "node refund.ts --serve",
    "llm": "node llm-agent.ts",
    "llm:serve": "node llm-agent.ts --serve",
    "sql": "node sql-agent.ts",
    "sql:probe": "node sql-agent.ts --probe",
    "sql:serve": "node sql-agent.ts --serve",
    "weather": "node weather-agent.ts",
    "weather:probe": "node weather-agent.ts --probe",
    "weather:serve": "node weather-agent.ts --serve",
    "concierge": "node concierge.ts",
    "concierge:probe": "node concierge.ts --probe",
    "concierge:serve": "node concierge.ts --serve"
  },
  "dependencies": {
    "@mekik/core": "workspace:*",
    "@mekik/langchain": "workspace:*",
    "@mekik/ws": "workspace:*",
    "@ilmek/core": "^0.1.1",
    "@langchain/anthropic": "^1.0.0",
    "@langchain/core": "^1.2.3",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "license": "MIT"
}
