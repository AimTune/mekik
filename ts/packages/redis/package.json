{
  "name": "@mekik/redis",
  "version": "0.2.0",
  "description": "Redis horizontal-scale backends for mekik — a SET NX PX turn lock and a Pub/Sub backplane, so a single-node app becomes a fleet with no engine changes.",
  "type": "module",
  "license": "MIT",
  "author": "AimTune",
  "homepage": "https://github.com/AimTune/mekik/tree/main/ts/packages/redis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AimTune/mekik.git",
    "directory": "ts/packages/redis"
  },
  "bugs": "https://github.com/AimTune/mekik/issues",
  "keywords": [
    "mekik",
    "redis",
    "backplane",
    "turn-lock",
    "horizontal-scale",
    "pub-sub",
    "realtime"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "node --test test/*.test.ts"
  },
  "dependencies": {
    "@mekik/core": "workspace:*"
  },
  "peerDependencies": {
    "ioredis": ">=5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
