    "@mekik/core": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3 <2"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.3",
    "@ilmek/core": "^0.1.1",
    "zod": "^3.25.0"
  }
