{
  "name": "@mekik/langchain",
  "version": "0.2.0",
  "description": "LangChain integration for mekik — surface agent tool calls in the UI, gate them behind human approval, and make them exactly-once across an interrupt/resume.",
  "type": "module",
  "license": "MIT",
  "author": "AimTune",
  "homepage": "https://github.com/AimTune/mekik/tree/main/ts/packages/langchain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AimTune/mekik.git",
    "directory": "ts/packages/langchain"
  },
  "bugs": "https://github.com/AimTune/mekik/issues",
  "keywords": [
    "mekik",
    "langchain",
    "ilmek",
    "tools",
    "human-in-the-loop",
    "generative-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
